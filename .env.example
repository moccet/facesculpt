# Slack incoming webhook used for booking-started, booking-submit,
# assessment-submit, newsletter notifications, and Stripe payment events.
# Same webhook the wellness site uses; messages distinguish themselves
# with a "FaceSculpt" prefix in the title.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/HERE

# Stripe — server keys. Used for Checkout (workouts, products, memberships)
# and the webhook handler at /api/stripe/webhook.
# Test keys: sk_test_… / whsec_… (point Stripe CLI at /api/stripe/webhook)
# Live keys: sk_live_… / whsec_…
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs for membership subscriptions. Create the recurring prices
# (£100/mo and £250/mo) in the Stripe Dashboard, then paste the IDs here.
# Standard = Sculpt Member, Plus = Sculpt Plus.
STRIPE_PRICE_MEMBERSHIP_STANDARD=price_replace_me_standard
STRIPE_PRICE_MEMBERSHIP_PLUS=price_replace_me_plus

# Optional. Used to build absolute success/cancel URLs for Stripe Checkout.
# If unset, the request origin is used. Set this in production so URLs are
# stable even when behind redirects/proxies.
NEXT_PUBLIC_SITE_URL=https://facesculpt.thewellnesslondon.com

# Future upgrade: account portal access via magic-link email rather than
# direct redirect. When wired up, /api/stripe/portal will email the
# Customer Portal URL instead of returning it inline. Suggested provider:
# Resend (https://resend.com/) — generous free tier, simple API.
# RESEND_API_KEY=re_replace_me
# RESEND_FROM_EMAIL=team@thewellnesslondon.com
